# Copy to .env when running API on your machine (not inside Docker)

ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql+asyncpg://REPLACE_ME:REPLACE_ME@localhost:5432/ecoai
DATABASE_URL_SYNC=postgresql://REPLACE_ME:REPLACE_ME@localhost:5432/ecoai

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

QDRANT_URL=http://localhost:6333

# Required for real AI reasoning (pick one)
GEMINI_API_KEY=
LLM_PROVIDER=gemini

# Optional — not needed for first test
GROQ_API_KEY=
TAVILY_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
