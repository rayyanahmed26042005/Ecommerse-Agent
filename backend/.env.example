# App
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL (PLACEHOLDERS - replace locally)
DATABASE_URL=postgresql+asyncpg://REPLACE_ME:REPLACE_ME@postgres:5432/ecoai
DATABASE_URL_SYNC=postgresql://REPLACE_ME:REPLACE_ME@postgres:5432/ecoai

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Qdrant
QDRANT_URL=http://qdrant:6333

# LLM (set GROQ_API_KEY for real reasoning; mock works offline)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
LLM_PROVIDER=mock

# Optional search
TAVILY_API_KEY=
BRAVE_API_KEY=

# Reddit reviews (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Auth
JWT_SECRET=change-me-in-production
OAUTH_ENABLED=false

# Observability
OTEL_ENABLED=false
JAEGER_ENDPOINT=http://jaeger:4317
LOG_LEVEL=INFO
